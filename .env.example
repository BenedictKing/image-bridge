# Copy this file to .env and fill in the providers you want to test.
# Live tests are opt-in and call real upstream APIs, so they may consume quota.

# Enable live tests if you prefer environment variables over CLI flags.
# Equivalent CLI flag: --run-live
IMAGE_BRIDGE_RUN_LIVE=0

# Optionally narrow execution to a single live case or filter dimension.
# Equivalent CLI flags:
#   --live-case <case-id>
#   --live-provider <provider>
#   --live-protocol <protocol>
#   --live-capability <generate|edit>
IMAGE_BRIDGE_LIVE_CASE=
IMAGE_BRIDGE_LIVE_PROVIDER=
IMAGE_BRIDGE_LIVE_PROTOCOL=
IMAGE_BRIDGE_LIVE_CAPABILITY=

# Global timeout in seconds for live requests.
IMAGE_BRIDGE_LIVE_TIMEOUT_SECONDS=300

# OpenAI-compatible provider settings.
# Required for cases:
#   openai-images-generate
#   openai-chat-generate
#   openai-images-edit-mask
#   openai-chat-edit
IMAGE_BRIDGE_OPENAI_API_KEY=
IMAGE_BRIDGE_OPENAI_MODEL=gpt-image-1
IMAGE_BRIDGE_OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini provider settings.
# Required for cases:
#   gemini-generate
#   gemini-edit-reference
IMAGE_BRIDGE_GEMINI_API_KEY=
IMAGE_BRIDGE_GEMINI_MODEL=gemini-2.5-flash-image-preview
IMAGE_BRIDGE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Example commands:
#   uv run --extra test python -m pytest --run-live tests/live -q
#   uv run --extra test python -m pytest --run-live --live-case openai-images-generate tests/live/test_generate.py -q
